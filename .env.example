# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit real credentials.

# ── Groq (classification + summarisation LLM) ────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from your Slack app (OAuth & Permissions → Bot User OAuth Token).
# Required bot scopes: channels:history, chat:write, channels:read,
#                      groups:history, groups:read (for private channels).
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Channel the bot reads requests from, and where it posts summaries.
# Bare name or ID both work ("requests" or "C0123ABCDEF").
SLACK_REQUESTS_CHANNEL=requests
SLACK_UPDATES_CHANNEL=team-updates

# ── Google (Sheets tracker + Calendar) ───────────────────────────────────────
# Path to your Google service-account JSON key file.
# The sheet AND the calendar must be shared with the service account's
# client_email address (give Editor access to both).
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Sheets tracker: long ID from the Sheet URL.
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Calendar: "primary" for your main calendar, or a specific calendar ID
# (find it in calendar.google.com → Settings → [calendar] → Calendar ID).
GOOGLE_CALENDAR_ID=primary

# ── Notion ────────────────────────────────────────────────────────────────────
# Used for BOTH the Notion tracker backend (if tracker.backend="notion")
# AND the standalone notion_* tools (notion_create_page etc.).
#
# Get your API key: notion.so/my-integrations → New Integration → copy key.
# Then share each database/page you want to access with that integration
# (three-dot menu → Add connections → your integration).
NOTION_API_KEY=secret_your_notion_api_key_here

# Used only when tracker.backend="notion":
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Email — SMTP ──────────────────────────────────────────────────────────────
# Gmail setup (recommended):
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to myaccount.google.com → Security → App Passwords.
#   3. Create one for "Mail" → use the 16-character password below.
#   4. SMTP_USERNAME and EMAIL_FROM_ADDRESS should be the same Gmail address.
#
# Other providers: change SMTP_HOST and SMTP_PORT accordingly.
#   Outlook:  smtp-mail.outlook.com  587
#   Yahoo:    smtp.mail.yahoo.com    587
#   Zoho:     smtp.zoho.com          587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password_here
EMAIL_FROM_ADDRESS=your_gmail@gmail.com
EMAIL_FROM_NAME=Team Ops Agent

# ── Telegram ──────────────────────────────────────────────────────────────────
# Setup (3 minutes):
#   1. Open Telegram → search @BotFather → /newbot → follow prompts.
#      Copy the bot token below.
#   2. Personal chat ID:
#      a. Send /start to your new bot.
#      b. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
#      c. Find "chat":{"id": <NUMBER>} → that's your TELEGRAM_CHAT_ID.
#   3. Group chat ID (optional — for team alerts):
#      a. Add the bot to your group.
#      b. Send a message in the group, then check getUpdates again.
#         Group IDs are negative (e.g. -1001234567890).
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_personal_chat_id_here
TELEGRAM_GROUP_ID=                            # optional, leave blank if unused

# ── Schedule timings (24-hour local system time) ──────────────────────────────
DAILY_SUMMARY_TIME=18:00
WEEKLY_SUMMARY_DAY=monday
WEEKLY_SUMMARY_TIME=09:00
