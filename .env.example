# ── Groq ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Slack ──────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_REQUESTS_CHANNEL=new-channel
SLACK_UPDATES_CHANNEL=new-channel

# ── Google Sheets ──────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_CALENDAR_ID=your@gmail.com

# ── Notion (optional — only if tracker.backend = "notion") ────────────────────
NOTION_API_KEY=secret_your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM_ADDRESS=your@gmail.com
EMAIL_FROM_NAME=Team Ops Agent

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_GROUP_ID=

# ── Schedule ───────────────────────────────────────────────────────────────────
DAILY_SUMMARY_TIME=18:00
WEEKLY_SUMMARY_DAY=monday
WEEKLY_SUMMARY_TIME=09:00
