# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real credentials.

# ── Groq (classification + summarisation LLM) ───────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Slack ──────────────────────────────────────────────────────────────────────
# Bot token from your Slack app (OAuth & Permissions -> Bot User OAuth Token).
# Required bot scopes: channels:history, chat:write (add groups:history too if
# the requests channel is private).
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Channel the bot reads incoming requests from, and the channel it posts
# summaries to. Can be the same channel or different ones. Bare name or ID
# both work (e.g. "requests" or "C0123ABCDEF").
SLACK_REQUESTS_CHANNEL=requests
SLACK_UPDATES_CHANNEL=team-updates

# ── Google Sheets (tracker backend) ─────────────────────────────────────────────
# Path to your Google service-account JSON key file. The sheet itself must be
# shared with the service account's email address (Editor access).
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
# The long ID in your Sheet's URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Notion (alternative tracker backend — only needed if config.yaml sets
#    tracker.backend to "notion") ───────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Email provider (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM_ADDRESS=onboarding@resend.dev
EMAIL_FROM_NAME=Team Ops Agent

# ── Schedule timings (24-hour format, local system time) ────────────────────────
DAILY_SUMMARY_TIME=18:00
WEEKLY_SUMMARY_DAY=monday
WEEKLY_SUMMARY_TIME=09:00
